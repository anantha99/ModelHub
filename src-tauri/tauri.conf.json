{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ModelHub Windows",
  "version": "0.1.1",
  "identifier": "dev.anantha.modelhub.windows",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ModelHub Windows",
        "width": 1180,
        "height": 760,
        "minWidth": 390,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "DeveloperTool",
    "publisher": "Anantha Kattani",
    "shortDescription": "Windows desktop app for managing local AI models",
    "longDescription": "ModelHub Windows scans, downloads, and manages local AI models across Hugging Face cache, LM Studio, Ollama, and configured model folders.",
    "homepage": "https://github.com/anantha99/ModelHub",
    "license": "MIT",
    "copyright": "Copyright (c) 2026 Anantha Kattani",
    "icon": ["icons/icon.ico"],
    "windows": {
      "allowDowngrades": false,
      "signCommand": {
        "cmd": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "scripts/sign-windows-preview.ps1",
          "-FilePath",
          "%1"
        ]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": false
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
